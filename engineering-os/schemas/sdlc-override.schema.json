{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.coding-autopilot.dev/engineering-os/sdlc-override.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["reason", "owner", "skippedGate", "risk", "compensatingVerification"],
  "properties": {
    "reason": { "type": "string", "minLength": 8 },
    "owner": { "type": "string", "minLength": 1 },
    "skippedGate": { "type": "string", "minLength": 1 },
    "risk": { "enum": ["low", "medium", "high", "critical"] },
    "compensatingVerification": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
