{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cas.coding-autopilot.dev/schemas/loop-pilot.schema.json",
  "type": "object",
  "required": ["schemaVersion", "scenario", "status", "bounded", "sourceCommits", "events", "assertions", "artifacts", "reproduce"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "scenario": { "enum": ["feature", "repair", "restart", "policy"] },
    "status": { "const": "passed" },
    "bounded": { "const": true },
    "sourceCommits": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" } },
    "events": { "type": "array", "minItems": 2, "items": { "type": "object", "required": ["sequence", "type", "outcome"], "properties": { "sequence": { "type": "integer", "minimum": 0 }, "type": { "type": "string", "minLength": 1 }, "outcome": { "type": "string", "minLength": 1 } } } },
    "assertions": { "type": "object", "minProperties": 1 },
    "artifacts": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^(cas|file)://" } },
    "reproduce": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
